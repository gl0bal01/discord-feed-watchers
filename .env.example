# Discord Feed Watchers - Environment Variables
# Copy this file to .env and fill in your webhook URLs.

# Discord webhook URL for CVE (CISA Known Exploited Vulnerabilities) alerts
CVE_WEBHOOK_URL=

# Discord webhook URL for FBI Most Wanted alerts
FBI_WEBHOOK_URL=

# Discord webhook URL for Europol Most Wanted alerts
EUROPOL_WEBHOOK_URL=

# Discord webhook URL for the Daily Fun message
FUN_WEBHOOK_URL=

# Override CVE data source (default: community CISA-KEV proxy). Official feed:
# https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.
CVE_FEED_URL=

# Discord webhook URL for Ransomware victim alerts
RANSOMWARE_WEBHOOK_URL=

# Country code to highlight in ransomware alerts (default: FR)
# RANSOMWARE_HIGHLIGHT_COUNTRY=FR
